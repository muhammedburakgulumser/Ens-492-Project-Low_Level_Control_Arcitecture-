// ── Yardımcı dönüşüm fonksiyonları ──────────────────────────────────────────
// Derece → Encoder tick
static inline long degreesToTicks(float deg) {
    return (long)((deg / 360.0f) * TICK_PER_REV);
}

// Encoder tick → Derece
static inline float ticksToDegrees(long ticks) {
    return ((float)ticks / TICK_PER_REV) * 360.0f;
}
