  /* Configure the system clock */
  SystemClock_Config();

  /* USER CODE BEGIN SysInit */

  /* USER CODE END SysInit */

  /* Initialize all configured peripherals */
  MX_GPIO_Init();
  MX_I2S3_Init();
  MX_SPI1_Init();
  MX_CAN1_Init();
  MX_TIM1_Init();
  MX_TIM2_Init();
  MX_USB_OTG_FS_HCD_Init();
  /* USER CODE BEGIN 2 */
  HAL_TIM_Encoder_Start(&htim1, TIM_CHANNEL_ALL);
  last_timer_cnt = __HAL_TIM_GET_COUNTER(&htim1);

  HAL_TIM_PWM_Start(&htim2, TIM_CHANNEL_1);
  HAL_TIM_PWM_Start(&htim2, TIM_CHANNEL_2);
  motorDur();

  CAN_Filter_Config();
  HAL_CAN_Start(&hcan1);
  HAL_CAN_ActivateNotification(&hcan1, CAN_IT_RX_FIFO0_MSG_PENDING);

  TxHeader.StdId = CAN_TX_ID;
  TxHeader.ExtId = 0x00;
  TxHeader.RTR   = CAN_RTR_DATA;
  TxHeader.IDE   = CAN_ID_STD;
  TxHeader.DLC   = 8;
  TxHeader.TransmitGlobalTime = DISABLE;
  /* USER CODE END 2 */

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */
    while (1)
    {
        // Force the PID to run exactly once every 1ms
        if ((HAL_GetTick() - lastPIDTime) >= 1)
        {
            lastPIDTime = HAL_GetTick();
            positionPID();
        }

        safetyCheck();

        // CAN Feedback loop (runs every 100ms)
        if ((HAL_GetTick() - lastCANFeedbackTime) > 100)
        {
            lastCANFeedbackTime = HAL_GetTick();

            float currentDeg = ticksToDegrees(encoderCount);
            float currentVel = 0.0f; // You can calculate actual velocity here later

            memcpy(&TxData[0], &currentDeg, 4);
            memcpy(&TxData[4], &currentVel, 4);

            if (HAL_CAN_GetTxMailboxesFreeLevel(&hcan1) > 0)
            {
                HAL_CAN_AddTxMessage(&hcan1, &TxHeader, TxData, &TxMailbox);
            }
        }
    /* USER CODE BEGIN 3 */
  }
  /* USER CODE END 3 */
}

