    f.FilterFIFOAssignment = CAN_RX_FIFO0;
    f.FilterIdHigh         = (uint32_t)CAN_RX_ID << 5;
    f.FilterIdLow          = 0x0000;
    f.FilterMaskIdHigh     = 0x7FF << 5;
    f.FilterMaskIdLow      = 0x0000;
    f.FilterMode           = CAN_FILTERMODE_IDMASK;
    f.FilterScale          = CAN_FILTERSCALE_32BIT;
    f.SlaveStartFilterBank = 14;
    HAL_CAN_ConfigFilter(&hcan1, &f);
}

void HAL_CAN_RxFifo0MsgPendingCallback(CAN_HandleTypeDef *hcan) {
    HAL_GPIO_TogglePin(GPIOD, LD4_Pin);

    if (HAL_CAN_GetRxMessage(hcan, CAN_RX_FIFO0, &RxHeader, RxData) == HAL_OK) {
        if (RxHeader.StdId == CAN_RX_ID) {
            uint8_t cmdType = RxData[0];
            float   floatVal;

            memcpy(&floatVal, &RxData[1], 4);   // tüm komutlar float

            switch (cmdType) {
                case 0:  // Pozisyon — derece gelir, tick'e çevir
                    targetPosition = degreesToTicks(floatVal);
                    lastCommandTime = HAL_GetTick();
                    integral  = 0.0f;
                    lastError = 0.0f;
                    break;
                case 2: Kp = floatVal; integral = 0.0f; break;
                case 3: Ki = floatVal; integral = 0.0f; break;
                case 4: Kd = floatVal; integral = 0.0f; break;
                case 5:  // Belt ratio güncelle
                    if (floatVal > 0.0f) {
                        BELT_RATIO   = floatVal;
                        TICK_PER_REV = (float)(PPR * QUADRATURE) * BELT_RATIO;
                        integral = 0.0f;
                    }
                    break;
                default: break;
            }
        }
    }
}
void safetyCheck(void)
{
    if (HAL_GetTick() - lastCommandTime > 300)
    {
        motorDur();
        integral = 0.0f;
        lastError = 0.0f;
        accelTarget = encoderCount;
    }
}

// ── Motor sürücü fonksiyonları (değişmedi) ───────────────────────────────────
void motorIleri(uint32_t pwm) {
    __HAL_TIM_SET_COMPARE(&htim2, TIM_CHANNEL_1, pwm);
    __HAL_TIM_SET_COMPARE(&htim2, TIM_CHANNEL_2, 0);
}

void motorGeri(uint32_t pwm) {
    __HAL_TIM_SET_COMPARE(&htim2, TIM_CHANNEL_1, 0);
    __HAL_TIM_SET_COMPARE(&htim2, TIM_CHANNEL_2, pwm);
}

void motorDur(void) {
    __HAL_TIM_SET_COMPARE(&htim2, TIM_CHANNEL_1, 0);
    __HAL_TIM_SET_COMPARE(&htim2, TIM_CHANNEL_2, 0);
}

void updateEncoder(void) {
    uint16_t current_cnt = __HAL_TIM_GET_COUNTER(&htim1);
    int16_t  delta       = (int16_t)(current_cnt - last_timer_cnt);
    encoderCount        += delta;
    last_timer_cnt       = current_cnt;
}

void positionPID(void)
{
    updateEncoder();

    float dt = 0.001f;

    long rawTarget = targetPosition;

    // ---- acceleration limiting (minimal) ----
    float maxStep = 2.0f;

    float delta = (float)rawTarget - lastTarget;

    if (delta > maxStep) delta = maxStep;
    if (delta < -maxStep) delta = -maxStep;

    accelTarget += delta;
    lastTarget = accelTarget;

    long error = (long)accelTarget - encoderCount;

    if (labs(error) < 5)
    {
        motorDur();
        integral = 0.0f;
        lastError = 0.0f;
        return;
    }


    float derivative = ((float)error - lastError) / dt;


    // 1. Accumulate the integral
        integral += (float)error * dt;

        // 2. ---- Direct PWM Clamping Anti-Windup ----
        float max_I_pwm = 20.0f; // Maximum PWM power the Integral term can ever exert

        if ((Ki * integral) > max_I_pwm)
        {
            integral = max_I_pwm / Ki;
        }
        else if ((Ki * integral) < -max_I_pwm)
        {
            integral = -max_I_pwm / Ki;
        }
    float output = Kp * error + Ki * integral + Kd * derivative;

    lastError = (float)error;

    int pwm = (int)fabsf(output);

    if (pwm > 100) pwm = 100;

    if (pwm < 3)
    {
        motorDur();
        return;
    }

    if (output > 0) motorIleri(pwm);
    else            motorGeri(pwm);
}
